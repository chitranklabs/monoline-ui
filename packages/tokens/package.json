{
	"name": "@chitrank2050/monoline-tokens",
	"version": "0.1.0",
	"description": "Private theme tokens and CSS variables used internally by Monoline UI.",
	"private": true,
	"author": {
		"name": "Chitrank Agnihotri",
		"email": "chitrank2050@gmail.com",
		"url": "https://www.chitrankagnihotri.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/chitrank2050/monoline-ui"
	},
	"bugs": {
		"url": "https://github.com/chitrank2050/monoline-ui/issues"
	},
	"keywords": [
		"design-tokens",
		"css-variables",
		"tailwindcss",
		"theming",
		"oklch",
		"private-workspace"
	],
	"sideEffects": [
		"./src/theme.css"
	],
	"exports": {
		".": "./src/index.ts",
		"./theme.css": "./src/theme.css"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json --emitDeclarationOnly",
		"biome-lint": "biome check .",
		"biome-lint:fix": "biome check --write .",
		"biome-format": "biome format --write .",
		"test": "vitest run --passWithNoTests"
	}
}
