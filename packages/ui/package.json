{
	"name": "@chitrank2050/monoline-ui",
	"version": "0.1.0",
	"description": "A React component library for polished interfaces built with Tailwind CSS and design-system principles.",
	"private": false,
	"author": {
		"name": "Chitrank Agnihotri",
		"email": "chitrank2050@gmail.com",
		"url": "https://www.chitrankagnihotri.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/chitrank2050/monoline-ui"
	},
	"bugs": {
		"url": "https://github.com/chitrank2050/monoline-ui/issues"
	},
	"keywords": [
		"react",
		"component-library",
		"design-system",
		"tailwindcss",
		"ui",
		"nextjs",
		"vite",
		"shadcn"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": [
		"./src/styles/theme.css"
	],
	"exports": {
		".": "./src/index.ts",
		"./theme.css": "./src/styles/theme.css"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json --emitDeclarationOnly",
		"biome-lint": "biome check .",
		"biome-lint:fix": "biome check --write .",
		"biome-format": "biome format --write .",
		"test": "vitest run"
	},
	"dependencies": {
		"@radix-ui/react-slot": "^1.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.511.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwind-merge": "^3.3.1"
	}
}
