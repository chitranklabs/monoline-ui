{
	"name": "@chitrank2050/monoline-ui",
	"version": "0.1.0",
	"description": "A React component library for polished interfaces built with Tailwind CSS and design-system principles.",
	"private": false,
	"author": {
		"name": "Chitrank Agnihotri",
		"email": "chitrank2050@gmail.com",
		"url": "https://www.chitrankagnihotri.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/chitrank2050/monoline-ui"
	},
	"bugs": {
		"url": "https://github.com/chitrank2050/monoline-ui/issues"
	},
	"type": "module",
	"keywords": [
		"react",
		"component-library",
		"design-system",
		"tailwindcss",
		"ui",
		"nextjs",
		"vite",
		"shadcn"
	],
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": [
		"./dist/styles/theme.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"development": "./src/index.ts",
			"import": "./dist/index.js"
		},
		"./theme.css": {
			"development": "./src/styles/theme.css",
			"default": "./dist/styles/theme.css"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/styles && cp src/styles/theme.css dist/styles/theme.css",
		"biome-lint": "biome check .",
		"biome-lint:fix": "biome check --write .",
		"biome-format": "biome format --write .",
		"prepack": "pnpm build",
		"test": "vitest run"
	},
	"peerDependencies": {
		"react": "^18.2.0 || ^19.0.0",
		"react-dom": "^18.2.0 || ^19.0.0"
	},
	"dependencies": {
		"@radix-ui/react-slot": "^1.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.511.0",
		"tailwind-merge": "^3.3.1"
	}
}
