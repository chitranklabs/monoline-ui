{
	"name": "monoline-ui",
	"version": "0.1.0",
	"description": "A modular design system and UI blueprint built from my portfolio’s visual language.",
	"private": true,
	"author": {
		"name": "Chitrank Agnihotri",
		"email": "chitrank2050@gmail.com",
		"url": "https://www.chitrankagnihotri.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/chitranklabs/monoline-ui"
	},
	"bugs": {
		"url": "https://github.com/chitranklabs/monoline-ui/issues"
	},
	"keywords": [
		"design-system",
		"component-library",
		"tailwindcss",
		"shadcn",
		"nextjs",
		"react",
		"monorepo"
	],
	"scripts": {
		"dev": "pnpm run dev:docs",
		"dev:docs": "pnpm --filter @chitrank2050/monoline-docs dev",
		"build": "turbo run build",
		"lint": "pnpm biome-lint && turbo run biome-lint",
		"lint:fix": "pnpm biome-lint:fix && turbo run biome-lint:fix",
		"format": "pnpm biome-format && turbo run biome-format",
		"format:check": "pnpm biome-format:check",
		"test": "turbo run test",
		"test:e2e": "playwright test",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"prepare": "husky",
		"commitlint": "commitlint --edit",
		"lint-staged": "lint-staged",
		"biome-lint": "biome check .",
		"biome-lint:fix": "biome check --write .",
		"biome-format": "biome format --write .",
		"biome-format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.0",
		"@changesets/cli": "^2.30.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@tailwindcss/postcss": "^4.2.0",
		"@playwright/test": "^1.58.0",
		"@testing-library/jest-dom": "^6.6.0",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.0",
		"@types/node": "^24.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.4.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.4.0",
		"next": "^16.2.2",
		"playwright": "^1.58.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwindcss": "^4.2.0",
		"turbo": "^2.9.0",
		"typescript": "^6.0.0",
		"vitest": "^4.1.0"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,json}": [
			"biome check --write --no-errors-on-unmatched",
			"biome lint --error-on-warnings ."
		]
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	}
}
