{
	"name": "monoline-ui",
	"version": "0.1.0",
	"description": "A modular design system and UI blueprint built from my portfolio’s visual language.",
	"private": true,
	"author": {
		"name": "Chitrank Agnihotri",
		"email": "chitrank2050@gmail.com",
		"url": "https://www.chitrankagnihotri.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/chitranklabs/monoline-ui"
	},
	"bugs": {
		"url": "https://github.com/chitranklabs/monoline-ui/issues"
	},
	"keywords": [
		"design-system",
		"component-library",
		"tailwindcss",
		"shadcn",
		"nextjs",
		"react",
		"monorepo"
	],
	"scripts": {
		"dev": "pnpm run dev:docs",
		"dev:docs": "pnpm --filter @chitrank2050/monoline-docs dev",
		"build": "turbo run build",
		"lint": "turbo run lint && eslint commitlint.config.mjs",
		"lint:fix": "turbo run lint:fix && eslint commitlint.config.mjs --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "turbo run test",
		"test:e2e": "playwright test",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"prepare": "husky",
		"commitlint": "commitlint --edit",
		"lint-staged": "lint-staged"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@changesets/cli": "^2.30.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@tailwindcss/postcss": "^4.2.0",
		"@playwright/test": "^1.59.1",
		"@testing-library/jest-dom": "^6.6.0",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.0",
		"@types/node": "^25.6.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^10.2.0",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"lint-staged": "^16.4.0",
		"next": "^16.2.0",
		"playwright": "^1.59.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"prettier": "^3.8.2",
		"tailwindcss": "^4.2.0",
		"turbo": "^2.9.6",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.4"
	},
	"lint-staged": {
		"*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,css,md,yml,yaml}": [
			"prettier --write"
		]
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	}
}
