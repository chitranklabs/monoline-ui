{
	"name": "foundry-ui",
	"version": "0.1.0",
	"description": "A modular design system and UI blueprint built from my portfolio’s visual language.",
	"private": false,
	"author": {
		"name": "Chitrank agnihotri",
		"email": "chitrank2050@gmail.com",
		"url": "https://wwww.chitrankagnihotri.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/chitrank2050/foundry-ui"
	},
	"bugs": {
		"url": "https://github.com/chitrank2050/foundry-ui/issues"
	},
	"keywords": [],
	"scripts": {
		"dev": "turbo run dev --parallel",
		"dev:docs": "pnpm --filter @foundry/docs dev",
		"build": "turbo run build",
		"lint": "pnpm biome-lint && turbo run biome-lint",
		"lint:fix": "pnpm biome-lint:fix && turbo run biome-lint:fix",
		"format": "pnpm biome-format && turbo run biome-format",
		"test": "turbo run test",
		"test:e2e": "playwright test",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"prepare": "husky",
		"commitlint": "commitlint --edit",
		"lint-staged": "lint-staged",
		"biome-lint": "biome check .",
		"biome-lint:fix": "biome check --write .",
		"biome-format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"@changesets/cli": "^2.29.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@tailwindcss/postcss": "^4.1.0",
		"@playwright/test": "^1.52.0",
		"@storybook/addon-a11y": "^9.0.0",
		"@storybook/addon-docs": "^9.0.0",
		"@storybook/addon-themes": "^9.0.0",
		"@storybook/nextjs-vite": "^9.0.0",
		"@testing-library/jest-dom": "^6.6.0",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.0",
		"@types/node": "^24.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.4.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.2.7",
		"next": "^16.1.6",
		"playwright": "^1.52.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"storybook": "^9.0.0",
		"tailwindcss": "^4.1.0",
		"turbo": "^2.5.0",
		"typescript": "^5.8.0",
		"vitest": "^3.1.0"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,json}": [
			"biome check --write --no-errors-on-unmatched",
			"biome lint --error-on-warnings ."
		]
	},
	"packageManager": "pnpm@10.6.2",
	"engines": {
		"node": ">=20.11.0",
		"pnpm": ">=10.0.0"
	}
}
